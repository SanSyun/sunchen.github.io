---
import { getCollection } from "astro:content";
import EntryCard from "../../components/EntryCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/i18n";

const projects = (await getCollection("zh-projects", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Projects | SUNCHEN" description="Project case studies and execution records.">
  <section class="page-header">
    <span class="eyebrow">Projects</span>
    <h1 class="page-title">Project records with a consistent English interface.</h1>
    <p class="lede">
      This page keeps the interface, labels, and structure in English while preserving your original project content.
    </p>
  </section>

  <section class="list-block">
    {projects.map((project) => (
      <EntryCard
        href={`/projects/${project.id}`}
        title={project.data.title}
        description={project.data.description}
        meta={[
          formatDate(project.data.date),
          project.data.role,
          project.data.duration,
          project.data.outcome
        ]}
        tags={project.data.stack}
      />
    ))}
  </section>
</BaseLayout>
