---
import { getCollection } from "astro:content";
import EntryCard from "../components/EntryCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate } from "../lib/i18n";

const projects = (await getCollection("zh-projects", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const notes = (await getCollection("zh-notes", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<BaseLayout
  title="SUNCHEN | 嵌入式系统个人站"
  description="SUNCHEN 的个人站，聚焦嵌入式 Linux 驱动、RTOS、MCU 与技术笔记。"
  locale="zh"
  switchHref="/en"
>
  <section class="hero">
    <div class="hero-card panel">
      <span class="eyebrow">Independent publication</span>
      <h1 class="hero-title">嵌入式系统开发记录与长期技术积累。</h1>
      <p class="lede">
        这里用来整理我的项目经历、学习笔记与工程思考，重点关注嵌入式 Linux 驱动、RTOS、
        MCU 以及底层系统开发。希望这个站点既是长期积累的归档，也能成为求职时直接可引用的作品入口。
      </p>
      <ul class="hero-meta">
        <li>嵌入式 Linux 驱动</li>
        <li>RTOS</li>
        <li>MCU</li>
        <li>Keep Hungry</li>
      </ul>
      <a class="button-link" href="/projects">查看项目归档</a>
    </div>

    <div class="hero-sidebar">
      <aside class="sidebar-card panel">
        <span class="small-label">求职方向</span>
        <p>嵌入式 Linux 驱动 / RTOS / MCU</p>
      </aside>
      <aside class="sidebar-card panel">
        <span class="small-label">联系</span>
        <p><a class="text-link" href="mailto:schen030@163.com">schen030@163.com</a></p>
      </aside>
      <aside class="sidebar-card panel">
        <span class="small-label">个人短句</span>
        <p>Keep Hungry</p>
      </aside>
    </div>
  </section>

  <section class="content-grid">
    <div class="content-card panel">
      <div class="meta-line" style="margin-bottom: 16px;">
        <span class="eyebrow">Selected projects</span>
      </div>
      <h2 class="section-title">最近的项目记录</h2>
      <div class="list-block">
        {projects.map((project) => (
          <EntryCard
            href={`/projects/${project.id}`}
            title={project.data.title}
            description={project.data.description}
            meta={[
              formatDate(project.data.date, "zh"),
              project.data.role,
              project.data.duration
            ]}
            tags={project.data.stack}
          />
        ))}
      </div>
    </div>

    <aside class="content-card panel">
      <div class="meta-line" style="margin-bottom: 16px;">
        <span class="eyebrow">Field notes</span>
      </div>
      <h2 class="section-title">最新笔记</h2>
      <div class="list-block">
        {notes.map((note) => (
          <article class="note-card">
            <div class="meta-line">
              <span>{note.data.category}</span>
              <span>{formatDate(note.data.date, "zh")}</span>
            </div>
            <h3><a class="text-link" href={`/notes/${note.id}`}>{note.data.title}</a></h3>
            <p>{note.data.description}</p>
          </article>
        ))}
      </div>
    </aside>
  </section>
</BaseLayout>
