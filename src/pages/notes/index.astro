---
import { getCollection } from "astro:content";
import EntryCard from "../../components/EntryCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/i18n";

const notes = (await getCollection("zh-notes", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Notes | SUNCHEN" description="Learning notes and technical writing.">
  <section class="page-header">
    <span class="eyebrow">Notes</span>
    <h1 class="page-title">An English interface for your original technical notes.</h1>
    <p class="lede">
      Navigation, section labels, and page structure are in English while your note content stays unchanged.
    </p>
  </section>

  <section class="list-block">
    {notes.map((note) => (
      <EntryCard
        href={`/notes/${note.id}`}
        title={note.data.title}
        description={note.data.description}
        meta={[
          formatDate(note.data.date),
          note.data.category,
          note.data.readingTime ?? "Short read"
        ]}
        tags={note.data.tags}
      />
    ))}
  </section>
</BaseLayout>
