---
import { getCollection } from "astro:content";
import EntryCard from "../../components/EntryCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/i18n";

const notes = (await getCollection("zh-notes", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Notes | Your Name" description="学习笔记、技术写作与方法总结。" locale="zh" switchHref="/en/notes">
  <section class="page-header">
    <span class="eyebrow">Notes</span>
    <h1 class="page-title">工作笔记、概念整理与可复用的技术总结。</h1>
    <p class="lede">
      优先写那些能解释一个概念、记录一次排障路径，或者比较多个技术方案的内容。它们既能帮助复习，也很适合面试中引用。
    </p>
  </section>

  <section class="list-block">
    {notes.map((note) => (
      <EntryCard
        href={`/notes/${note.id}`}
        title={note.data.title}
        description={note.data.description}
        meta={[
          formatDate(note.data.date, "zh"),
          note.data.category,
          note.data.readingTime ?? "短文"
        ]}
        tags={note.data.tags}
      />
    ))}
  </section>
</BaseLayout>

