---
import { getCollection } from "astro:content";
import EntryCard from "../../../components/EntryCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { formatDate } from "../../../lib/i18n";

const notes = (await getCollection("en-notes", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Notes | Your Name" description="Learning notes, technical writing, and reflections." locale="en" switchHref="/notes">
  <section class="page-header">
    <span class="eyebrow">Notes</span>
    <h1 class="page-title">Working notes, distilled ideas, and technical references.</h1>
    <p class="lede">
      Favor notes that explain a concept, document a debugging path, or compare technical options.
      Those pieces become useful both for revision and for interviews.
    </p>
  </section>

  <section class="list-block">
    {notes.map((note) => (
      <EntryCard
        href={`/en/notes/${note.id}`}
        title={note.data.title}
        description={note.data.description}
        meta={[
          formatDate(note.data.date, "en"),
          note.data.category,
          note.data.readingTime ?? "Short read"
        ]}
        tags={note.data.tags}
      />
    ))}
  </section>
</BaseLayout>

