---
import { getCollection } from "astro:content";
import EntryCard from "../../../components/EntryCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { formatDate } from "../../../lib/i18n";

const notes = (await getCollection("zh-notes", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Notes | SUNCHEN" description="Learning notes and technical writing." locale="en" switchHref="/notes">
  <section class="page-header">
    <span class="eyebrow">Notes</span>
    <h1 class="page-title">English interface, original Chinese articles.</h1>
    <p class="lede">
      Navigation, section labels, and page structure are translated, but the notes themselves remain
      in their original Chinese version.
    </p>
  </section>

  <section class="list-block">
    {notes.map((note) => (
      <EntryCard
        href={`/en/notes/${note.id}`}
        title={note.data.title}
        description={note.data.description}
        meta={[
          formatDate(note.data.date, "en"),
          note.data.category,
          note.data.readingTime ?? "Short read"
        ]}
        tags={note.data.tags}
      />
    ))}
  </section>
</BaseLayout>
