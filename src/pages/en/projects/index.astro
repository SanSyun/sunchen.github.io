---
import { getCollection } from "astro:content";
import EntryCard from "../../../components/EntryCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { formatDate } from "../../../lib/i18n";

const projects = (await getCollection("en-projects", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Projects | Your Name" description="Project case studies and execution records." locale="en" switchHref="/projects">
  <section class="page-header">
    <span class="eyebrow">Projects</span>
    <h1 class="page-title">Case studies, shipped work, and technical decisions.</h1>
    <p class="lede">
      Write each project like a compact research record: background, responsibility, architecture,
      tradeoffs, and outcome. That format makes your resume links far stronger.
    </p>
  </section>

  <section class="list-block">
    {projects.map((project) => (
      <EntryCard
        href={`/en/projects/${project.id}`}
        title={project.data.title}
        description={project.data.description}
        meta={[
          formatDate(project.data.date, "en"),
          project.data.role,
          project.data.duration,
          project.data.outcome
        ]}
        tags={project.data.stack}
      />
    ))}
  </section>
</BaseLayout>

