---
import { getCollection } from "astro:content";
import EntryCard from "../../components/EntryCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/i18n";

const projects = (await getCollection("en-projects", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const notes = (await getCollection("en-notes", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<BaseLayout
  title="Your Name | Publication-style personal site"
  description="A publication-style portfolio for projects, learning notes, and writing."
  locale="en"
  switchHref="/"
>
  <section class="hero">
    <div class="hero-card panel">
      <span class="eyebrow">Independent publication</span>
      <h1 class="hero-title">Build a body of work that reads like evidence.</h1>
      <p class="lede">
        This site is designed to present projects, engineering notes, and long-form reflections with
        the clarity of an editorial publication. It is built for calm reading, quick scanning, and
        future resume links.
      </p>
      <ul class="hero-meta">
        <li>Project case studies</li>
        <li>Learning notes</li>
        <li>Markdown-first workflow</li>
      </ul>
      <a class="button-link" href="/en/projects">Enter the archive</a>
    </div>

    <div class="hero-sidebar">
      <aside class="sidebar-card panel">
        <span class="small-label">Positioning</span>
        <p>
          A focused personal site for job applications: proof of execution, technical depth, and
          thoughtful writing.
        </p>
      </aside>
      <aside class="sidebar-card panel">
        <span class="small-label">Recommended sections</span>
        <ul class="stat-list">
          <li>Featured projects</li>
          <li>Notes by topic</li>
          <li>Resume page</li>
          <li>About + contact</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="content-grid">
    <div class="content-card panel">
      <div class="meta-line" style="margin-bottom: 16px;">
        <span class="eyebrow">Selected projects</span>
      </div>
      <h2 class="section-title">Recent project records</h2>
      <div class="list-block">
        {projects.map((project) => (
          <EntryCard
            href={`/en/projects/${project.id}`}
            title={project.data.title}
            description={project.data.description}
            meta={[
              formatDate(project.data.date, "en"),
              project.data.role,
              project.data.duration
            ]}
            tags={project.data.stack}
          />
        ))}
      </div>
    </div>

    <aside class="content-card panel">
      <div class="meta-line" style="margin-bottom: 16px;">
        <span class="eyebrow">Field notes</span>
      </div>
      <h2 class="section-title">Latest writing</h2>
      <div class="list-block">
        {notes.map((note) => (
          <article class="note-card">
            <div class="meta-line">
              <span>{note.data.category}</span>
              <span>{formatDate(note.data.date, "en")}</span>
            </div>
            <h3><a class="text-link" href={`/en/notes/${note.id}`}>{note.data.title}</a></h3>
            <p>{note.data.description}</p>
          </article>
        ))}
      </div>
    </aside>
  </section>
</BaseLayout>



