---
import { getCollection } from "astro:content";
import EntryCard from "../../components/EntryCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/i18n";

const projects = (await getCollection("zh-projects", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const notes = (await getCollection("zh-notes", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<BaseLayout
  title="SUNCHEN | Embedded Systems Publication"
  description="SUNCHEN's personal site focused on Embedded Linux drivers, RTOS, MCU, and technical notes."
  locale="en"
  switchHref="/"
>
  <section class="hero">
    <div class="hero-card panel">
      <span class="eyebrow">Independent publication</span>
      <h1 class="hero-title">Embedded systems work, notes, and long-term technical accumulation.</h1>
      <p class="lede">
        This site organizes my project records, study notes, and engineering reflections, with a focus
        on Embedded Linux drivers, RTOS, MCU, and low-level systems development. The interface is
        bilingual, while the technical articles remain in their original Chinese form.
      </p>
      <ul class="hero-meta">
        <li>Embedded Linux Drivers</li>
        <li>RTOS</li>
        <li>MCU</li>
        <li>Keep Hungry</li>
      </ul>
      <a class="button-link" href="/en/projects">Browse projects</a>
    </div>

    <div class="hero-sidebar">
      <aside class="sidebar-card panel">
        <span class="small-label">Focus</span>
        <p>Embedded Linux Drivers / RTOS / MCU</p>
      </aside>
      <aside class="sidebar-card panel">
        <span class="small-label">Contact</span>
        <p><a class="text-link" href="mailto:schen030@163.com">schen030@163.com</a></p>
      </aside>
      <aside class="sidebar-card panel">
        <span class="small-label">Motto</span>
        <p>Keep Hungry</p>
      </aside>
    </div>
  </section>

  <section class="content-grid">
    <div class="content-card panel">
      <div class="meta-line" style="margin-bottom: 16px;">
        <span class="eyebrow">Selected projects</span>
      </div>
      <h2 class="section-title">Recent project records</h2>
      <div class="list-block">
        {projects.map((project) => (
          <EntryCard
            href={`/en/projects/${project.id}`}
            title={project.data.title}
            description={project.data.description}
            meta={[
              formatDate(project.data.date, "en"),
              project.data.role,
              project.data.duration
            ]}
            tags={project.data.stack}
          />
        ))}
      </div>
    </div>

    <aside class="content-card panel">
      <div class="meta-line" style="margin-bottom: 16px;">
        <span class="eyebrow">Field notes</span>
      </div>
      <h2 class="section-title">Latest notes</h2>
      <div class="list-block">
        {notes.map((note) => (
          <article class="note-card">
            <div class="meta-line">
              <span>{note.data.category}</span>
              <span>{formatDate(note.data.date, "en")}</span>
            </div>
            <h3><a class="text-link" href={`/en/notes/${note.id}`}>{note.data.title}</a></h3>
            <p>{note.data.description}</p>
          </article>
        ))}
      </div>
    </aside>
  </section>
</BaseLayout>
